{
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(*)",
      "WebFetch(domain:myfitnesspalapi.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.myfitnesspal.com)",
      "Bash(find /workspace *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git -C *)",
      "Bash(git stash *)",
      "Bash(aws --version)",
      "Bash(aws cloudformation *)",
      "Bash(aws secretsmanager *)",
      "Bash(sam --version)",
      "Bash(sam validate *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(pip show *)",
      "Bash(pip list *)",
      "Bash(pip3 show *)",
      "Bash(pytest *)",
      "Bash(env LC_ALL=C bash /workspace/.claude/hooks/evaluate.sh)",
      "Bash(echo *)",
      "Bash(python3 /workspace/*)",
      "Bash(python3 -m *)",
      "Bash(python /workspace/*)",
      "Bash(python -m *)",
      "Bash(python3 -c *)",
      "Bash(python -c *)",
      "Bash(mypy *)",
      "Bash(ruff check *)",
      "Bash(bash -c *)",
      "Bash(bash --version)",
      "Bash(apt-get list *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/allow_dev_commands.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /workspace/.claude/hooks/evaluate-on-stop.sh"
          },
          {
            "type": "command",
            "command": "bash /workspace/.claude/hooks/log-progress.sh"
          }
        ]
      }
    ]
  }
}
