{
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(*)",
      "Bash(find *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(aws --version)",
      "Bash(sam --version)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(pip show *)",
      "Bash(pip list *)",
      "Bash(pip3 show *)",
      "Bash(pytest *)",
      "Bash(env LC_ALL=C bash /workspace/.claude/hooks/evaluate.sh)",
      "Bash(echo *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(mypy *)",
      "Bash(python -c *)",
      "WebFetch(domain:myfitnesspalapi.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/allow_dev_commands.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "env LC_ALL=C bash .claude/hooks/evaluate.sh"
          }
        ]
      }
    ]
  }
}
