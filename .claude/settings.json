{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(aws --version)",
      "Bash(sam --version)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(python3 -c ' *)",
      "Bash(pip show *)",
      "Bash(pip list *)",
      "Bash(python3 -m pytest tests/test_asken_client.py -v)",
      "Bash(python -m pytest tests/test_asken_client.py -v)",
      "Read(//usr/**)",
      "Read(//opt/**)",
      "Read(//home/node/.local/**)",
      "Bash(pip3 show *)",
      "Bash(pytest tests/test_asken_client.py -v)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evaluate.sh"
          }
        ]
      }
    ]
  }
}
